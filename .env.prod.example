# =============================================================================
# Plantilla de variables de entorno para PRODUCCIÓN.
# Copiá este archivo a `.env.prod` y completá los valores reales.
#   cp .env.prod.example .env.prod
# `.env.prod` está en .gitignore: NO se sube al repositorio.
# =============================================================================

# Clave secreta de Django. Generá una nueva (NO reutilices la de desarrollo):
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=REEMPLAZAR-por-una-clave-larga-y-aleatoria

# En producción SIEMPRE False.
DEBUG=False

# Dominios que servirán la app (separados por coma, sin esquema http/https).
ALLOWED_HOSTS=tudominio.com,www.tudominio.com

# Orígenes de confianza para CSRF (CON esquema, normalmente https).
CSRF_TRUSTED_ORIGINS=https://tudominio.com,https://www.tudominio.com

# ---------------------------------------------------------------------------
# Base de datos PostgreSQL.
# DB_HOST=db  -> nombre del servicio de Postgres en compose.prod.yaml.
# ---------------------------------------------------------------------------
DB_NAME=sigfrid
DB_USER=sigfrid
DB_PASSWORD=REEMPLAZAR-por-una-password-fuerte
DB_HOST=db
DB_PORT=5432

# ---------------------------------------------------------------------------
# Seguridad HTTPS. Dejalos comentados hasta tener un certificado TLS delante;
# si los activás sin HTTPS real, el sitio entra en bucle de redirección.
# ---------------------------------------------------------------------------
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000

# Nivel de logs de Django (DEBUG, INFO, WARNING, ERROR).
DJANGO_LOG_LEVEL=INFO
